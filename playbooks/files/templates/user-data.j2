#cloud-config

hostname: {{ vm_name }}
fqdn: {{ vm_name }}.local
users:
  - name: cloud-user
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    groups: users, wheel
    shell: /bin/bash
    ssh-authorized-keys:
      - ssh-rsa  sonal@fedora

runcmd:
  - systemctl enable sshd --now
  - curl -fsSL https://tailscale.com/install.sh | sh && sudo tailscale up --auth-key="{{ tailscale_auth_key }}"
  - dnf update -y
